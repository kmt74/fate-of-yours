# Fate of Yours — Environment Variables (Template)
# Copy this file to .env and fill in your actual keys.

# ── Supabase (Frontend) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# ── Supabase (Import Script — KHÔNG expose ra frontend) ───────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Path to JSONL data file (for import script only)
JSONL_PATH=./scripts/data/labyrinthos_parsed_features.jsonl

# ── Gemini AI (SERVER ONLY) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gemini AI (FRONTEND) ──────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
