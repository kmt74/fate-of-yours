# Fate of Yours — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_public_key...

# ── Import Script Only (NOT exposed to frontend) ──────────────────────────────
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key...

# Path to JSONL data file (for import script only)
JSONL_PATH=C:/Users/ADMIN/Downloads/labyrinthos_parsed_features.jsonl

# ── Gemini AI ─────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
